# Release signing configuration — copy this file to keystore.properties (which is gitignored)
# and fill in your own values. Never commit the real keystore.properties or the .jks file.
#
# storeFile is resolved relative to the project root. Prefer keeping the keystore OUTSIDE the
# repository (an absolute path) so it can never be committed by accident.

storeFile=../mediacenter-upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
